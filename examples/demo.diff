--- /dev/null
+++ b/app/access/members.py
@@ -0,0 +1,22 @@
+"""Board membership: list / invite collaborators."""
+from app.db import db
+from app.errors import NotFound
+from app.models.board import BoardMember
+from app.models.user import User
+
+
+def list_members(board):
+    rows = BoardMember.query.filter_by(board_id=board.id).all()
+    return [
+        {"user_id": m.user_id, "email": m.user.email, "role": m.role}
+        for m in rows
+    ]
+
+
+def invite(board, email, role="viewer"):
+    user = User.query.filter_by(email=email).first()
+    if user is None:
+        raise NotFound(f"no user with email {email}")
+    member = BoardMember(board_id=board.id, user_id=user.id, role=role)
+    db.session.add(member)
+    db.session.commit()
+    return member
