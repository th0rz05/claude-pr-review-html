@@ -0,0 +1,32 @@
+"""Membership-based access checks. Replaces the old owner-only model: a board
+is now shared with members, each carrying a role (viewer / editor / owner)."""
+from app.models.board import BoardMember
+from app.errors import Forbidden, NotFound
+
+VIEWER, EDITOR, OWNER = "viewer", "editor", "owner"
+_RANK = {VIEWER: 0, EDITOR: 1, OWNER: 2}
+
+
+def _role(user, board):
+    m = BoardMember.query.filter_by(board_id=board.id, user_id=user.id).first()
+    return m.role if m else None
+
+
+def can_view(user, board):
+    return _role(user, board) is not None
+
+
+def can_edit(user, board):
+    role = _role(user, board)
+    return role is not None and _RANK[role] >= _RANK[EDITOR]
+
+
+def require_view(user, board):
+    # 404 (not 403) so we never reveal a board the caller can't see.
+    if not can_view(user, board):
+        raise NotFound()
+
+
+def require_edit(user, board):
+    if not can_edit(user, board):
+        raise Forbidden("editor role required")
diff --git a/app/access/members.py b/app/access/members.py
new file mode 100644
